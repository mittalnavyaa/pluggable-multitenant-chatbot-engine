# ─────────────────────────────────────────────────────────────────────────────
# Envoy Mock Express Server — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit your .env file to version control.
# The .env file is listed in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Server Configuration ────────────────────────────────────────────────────

# Port the Express server listens on.
# The HTML demo page connects to http://localhost:PORT.
PORT=3000

# Node environment. Use "development" locally, "production" in deployment.
NODE_ENV=development

# ─── Backend SDK Configuration ───────────────────────────────────────────────
# These four variables are passed directly to createChatbotSDK().
# All four are REQUIRED. The server will refuse to start if any are missing.

# Base URL of the core FastAPI backend (apps/central-hub-backend).
# In development, this is the local uvicorn server.
# In production, this is your deployed backend URL.
CHATBOT_API_BASE=http://localhost:8000

# Your platform API key.
# This is injected into the X-Envoy-API-Key header on every proxied request.
# Obtain this from the admin dashboard under API Keys.
# Replace this placeholder with your actual key.
CHATBOT_API_KEY=envoy_dev_key_replace_me

# Your tenant product ID.
# This identifies which product workspace the SDK is operating on behalf of.
# Must match a product_id that exists in the internal_products table.
# Example values: tensor, admissions, hr-portal, placement-cell
CHATBOT_PRODUCT_ID=tensor

# Cryptographic signing secret for HMAC-SHA256 request signatures.
# This secret is shared between this server and the core backend.
# It is used to sign outgoing requests and verify incoming ones.
# NEVER expose this value to the browser or commit it to version control.
# Use a long, random string in production (minimum 32 characters).
CHATBOT_SIGNING_SECRET=dev_signing_secret_replace_me
