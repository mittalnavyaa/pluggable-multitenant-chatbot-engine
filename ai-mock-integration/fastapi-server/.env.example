# ─────────────────────────────────────────────────────────────────────────────
# Envoy Mock FastAPI Server — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit your .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Server Configuration ────────────────────────────────────────────────────

# Port the FastAPI server listens on.
# NOTE: Use 8001 to avoid conflicting with the core backend on 8000.
# If you are running the FastAPI demo instead of the core backend, use 8000.
PORT=8001

# Environment name. Use "development" locally, "production" in deployment.
ENVIRONMENT=development

# ─── Backend SDK Configuration ───────────────────────────────────────────────
# These variables configure the HMAC signing and request forwarding.

# Your platform API key.
# Injected into the X-Envoy-API-Key header on every proxied request.
CHATBOT_API_KEY=envoy_dev_key_replace_me

# Your tenant product ID.
# Must match a product_id that exists in the internal_products table.
# Example values: tensor, admissions, hr-portal, placement-cell
CHATBOT_PRODUCT_ID=tensor

# Cryptographic signing secret for HMAC-SHA256 request signatures.
# Must match the secret configured in the core backend.
# NEVER expose this value to the browser or commit it to version control.
CHATBOT_SIGNING_SECRET=dev_signing_secret_replace_me
